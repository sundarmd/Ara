# Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# Mistral API (REQUIRED)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_ENDPOINT=https://api.mistral.ai/v1/ocr
MISTRAL_CHAT_ENDPOINT=https://api.mistral.ai/v1/chat/completions
MISTRAL_CHAT_MODEL=mistral-large-latest

# Embedding Model
EMBEDDING_MODEL_NAME=mistral-embed

# Vector Database Directory
VECTOR_DB_DIR=./data/vector_store

# Data Storage Directories
DATA_DIR=./data/reports
IMAGES_DIR=./data/images
RECOMMENDATIONS_PATH=./data/recommendations.json

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Web Search (Tavily)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxx
